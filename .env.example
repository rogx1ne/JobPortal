DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
LOG_LEVEL=INFO

DB_NAME=career_aggregator
DB_USER=career_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306

# App controls
SEARCH_RATE_LIMIT_PER_MINUTE=30

# Optional security hardening (typically enable only behind HTTPS)
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=3600
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# Optional: enable Adzuna aggregation (requires free API credentials)
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=us
