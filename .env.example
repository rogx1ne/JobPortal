# Django
DJANGO_ENV=local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (MySQL)
DB_NAME=job_portal
DB_USER=job_portal
DB_PASSWORD=job_portal_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# Logging
LOG_LEVEL=INFO
